#--------------------------------------------------------------
#update once on start
#--------------------------------------------------------------
func _ready():
	#Noise
	noise.noise_type = FastNoiseLite.TYPE_PERLIN
	noise.frequency = 0.05
	
	spawn_player()
	texture() #give texture
	
	for z in range(world_size_z):
		for y in range(world_size_y):
			for x in range(world_size_x):
				chunks_to_generate.append(Vector3(x, y, z))
				
#--------------------------------------------------------------
#update per frame
#--------------------------------------------------------------
func _process(delta):
	get_hud_debug()
	# --- START NEW CHUNKS (non-blocking) ---
	for i in range(chunks_per_frame):
		if current_chunk_index >= chunks_to_generate.size():
			break

		var chunk_pos = chunks_to_generate[current_chunk_index]
		generate_one_chunk(chunk_pos)
		current_chunk_index += 1

	# --- FINISH THREADS (async completion) ---
	for t in active_threads:
		var thread = t.thread

		if thread.is_started() and not thread.is_alive():
			thread.wait_to_finish()

			var st = t.payload.result
			var chunk = t.payload.chunk_node

			var mesh = st.commit()
			var mi = MeshInstance3D.new()
			mi.mesh = mesh
			chunk.add_child(mi)

			active_threads.erase(t)
			break
	

