func generate_one_chunk(chunk_pos):

	var chunk = Node3D.new()
	add_child(chunk)
	chunk.position = chunk_pos * Chunk_SIZE

	# block data (same as before)
	var block_position_index = []
	var chunk_data = ChunkData.new()
	var size = Chunk_SIZE * Chunk_SIZE * Chunk_SIZE
	block_position_index.resize(size)

	for z in range(Chunk_SIZE):
		for y in range(Chunk_SIZE):
			for x in range(Chunk_SIZE):
				var i = x + y * Chunk_SIZE + z * Chunk_SIZE * Chunk_SIZE
				var world_x = chunk_pos.x * Chunk_SIZE + x
				var world_y = chunk_pos.y * Chunk_SIZE + y
				var world_z = chunk_pos.z * Chunk_SIZE + z

				var key = Vector3i(world_x, world_y, world_z)
				
				#spawn this block
				var block_type = terrain_or_what_being_placed(world_x, world_y, world_z)
				if block_type != AIR:
					chunk_data.blocks[Vector3i(x, y, z)] = block_type
				block_position_index[i] = block_type
				
				#tell me what is at 1 1 1 xyz
				if world_x == 1 and world_y == 1 and world_z == 1:
					print("BLOCK AT (1,1,1) =", block_type)

	# STORE IT HERE
	world_blocks[chunk_pos] = chunk_data
	# -------------------------------
	# START THREAD
	var thread = Thread.new()

	var payload = {
		"data": chunk_data,
		"chunk_pos": chunk_pos,
		"chunk_node": chunk
	}

	var err = thread.start(Callable(self, "_generate_chunk_mesh").bind(payload))

	if err != OK:
		push_error("THREAD FAILED")
		return

	active_threads.append({
		"thread": thread,
		"payload": payload
	})


func _generate_chunk_mesh(payload):
	var data = payload.data
	var st = SurfaceTool.new()

	st.begin(Mesh.PRIMITIVE_TRIANGLES)
	st.set_smooth_group(-1)

	# CHANGE THIS LINE: Use the shader material we made in texture()
	st.set_material(voxel_material) 

	for axis in range(3):
		greedy_mesh_axis_by_block(st, data, axis)

	payload["result"] = st


func greedy_mesh_axis_by_block(st, data, axis):
	var size = Chunk_SIZE
	var u = (axis + 1) % 3
	var v = (axis + 2) % 3
	
	var x = Vector3i()
	var mask = []
	mask.resize(size * size)

	# 1. Loop through slices
	for d in range(-1, size):
		mask.fill(null) # Reset mask for this slice

		# 2. Build the mask in ONE pass for ALL block types
		for i in range(size):
			for j in range(size):
				x[axis] = d
				x[u] = i
				x[v] = j
				var a = get_block(data, x)

				x[axis] = d + 1
				var b = get_block(data, x)

				# Logic: We only care if the blocks are different
				if a != b:
					if a != AIR: # Face pointing "forward"
						mask[i + j * size] = {"block": a, "dir": 1}
					elif b != AIR: # Face pointing "backward"
						mask[i + j * size] = {"block": b, "dir": -1}

		# 3. Build quads from the mask
		for j in range(size):
			for i in range(size):
				var cell = mask[i + j * size]
				if cell == null: continue

				# Compute width (w)
				var w = 1
				while i + w < size:
					var n = mask[(i + w) + j * size]
					if n == null or n["dir"] != cell["dir"] or n["block"] != cell["block"]:
						break
					w += 1

				# Compute height (h)
				var h = 1
				var done = false
				while j + h < size:
					for k in range(w):
						var n = mask[(i + k) + (j + h) * size]
						if n == null or n["dir"] != cell["dir"] or n["block"] != cell["block"]:
							done = true
							break
					if done: break
					h += 1

				# Emit the merged quad
				var pos = Vector3i()
				pos[axis] = d + 1
				pos[u] = i
				pos[v] = j

				var size_vec = Vector3i()
				size_vec[u] = w
				size_vec[v] = h

				emit_quad(st, axis, pos, size_vec, cell["dir"], cell["block"])

				# Clear the mask for the area we just used
				for y_rel in range(h):
					for x_rel in range(w):
						mask[(i + x_rel) + (j + y_rel) * size] = null

func get_block(data, pos: Vector3i) -> int:
	if pos.x < 0 or pos.y < 0 or pos.z < 0:
		return AIR
	if pos.x >= Chunk_SIZE or pos.y >= Chunk_SIZE or pos.z >= Chunk_SIZE:
		return AIR

	return data.blocks.get(pos, AIR)

func emit_quad(st, axis, pos: Vector3i, size: Vector3i, dir: int, block_type: int):
	var u = (axis + 1) % 3
	var v = (axis + 2) % 3

	var tex_index = float(block_type - 1)
	st.set_color(Color(tex_index, 0, 0))

	var origin = Vector3(pos)
	var du = Vector3(); du[u] = size[u]
	var dv = Vector3(); dv[v] = size[v]

	var v0 = origin
	var v1 = origin + du
	var v2 = origin + du + dv
	var v3 = origin + dv

	var uv0 = Vector2(0, 0)
	var uv1 = Vector2(size[u], 0)
	var uv2 = Vector2(size[u], size[v])
	var uv3 = Vector2(0, size[v])

	# This logic reverses the winding so the "front" faces outward
	if dir > 0:
		# Triangle 1
		st.set_uv(uv0); st.add_vertex(v0)
		st.set_uv(uv2); st.add_vertex(v2)
		st.set_uv(uv1); st.add_vertex(v1)
		# Triangle 2
		st.set_uv(uv0); st.add_vertex(v0)
		st.set_uv(uv3); st.add_vertex(v3)
		st.set_uv(uv2); st.add_vertex(v2)
	else:
		# Triangle 1
		st.set_uv(uv0); st.add_vertex(v0)
		st.set_uv(uv1); st.add_vertex(v1)
		st.set_uv(uv2); st.add_vertex(v2)
		# Triangle 2
		st.set_uv(uv0); st.add_vertex(v0)
		st.set_uv(uv2); st.add_vertex(v2)
		st.set_uv(uv3); st.add_vertex(v3)

#-----------------------------------------------------------------
#Noise or biome or terrain in here
#-----------------------------------------------------------------
func terrain_or_what_being_placed(world_x, world_y, world_z):
	var height_value = noise.get_noise_2d(world_x, world_z)

	# convert from -1..1 → 0..1
	height_value = (height_value + 1.0) * 0.5
	max_height = Chunk_SIZE * world_size_y
	
	var terrain_height = int(height_value * max_height)
	
	# 1) check first so it correct, basically bedrock
	if world_y == 0:
		return WATU
	# 2) terrain
	if world_y < terrain_height:
		return DIRT
	# 3) empty space
	return AIR
	
#--------------------------------------------------------------
# MESH GENERATION
func _build_cube_chunk(st, x, y, z, data, chunk_pos, block_type):
	var tile = get_block_atlas(block_type)
	var tile_size = Vector2(1.0 / ATLAS_SIZE.x, 1.0 / ATLAS_SIZE.y)
	var offset = tile * tile_size
	
	for face in FACES:
		var direction = face.dir

		var local = Vector3i(x, y, z) + Vector3i(direction)

		# check neighbor inside SAME chunk
		if local.x >= 0 and local.x < Chunk_SIZE \
		and local.y >= 0 and local.y < Chunk_SIZE \
		and local.z >= 0 and local.z < Chunk_SIZE:

			if data.blocks.get(local, AIR) != AIR:
				continue

		var v = face.verts

		var v0 = Vector3(x, y, z) + v[0]
		var v1 = Vector3(x, y, z) + v[1]
		var v2 = Vector3(x, y, z) + v[2]
		var v3 = Vector3(x, y, z) + v[3]

		st.set_uv(offset + Vector2(0, 0) * tile_size)
		st.add_vertex(v0)

		st.set_uv(offset + Vector2(1, 1) * tile_size)
		st.add_vertex(v2)

		st.set_uv(offset + Vector2(1, 0) * tile_size)
		st.add_vertex(v1)


		st.set_uv(offset + Vector2(0, 0) * tile_size)
		st.add_vertex(v0)

		st.set_uv(offset + Vector2(0, 1) * tile_size)
		st.add_vertex(v3)

		st.set_uv(offset + Vector2(1, 1) * tile_size)
		st.add_vertex(v2)
		
