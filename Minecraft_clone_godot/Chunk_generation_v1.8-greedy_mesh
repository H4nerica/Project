func get_atlas_size() -> Vector2i:
	var max_x = 0
	var max_y = 0

	for id in BLOCKS:
		var atlas_pos = BLOCKS[id]["atlas"]

		if atlas_pos.x < 0 or atlas_pos.y < 0:
			continue

		if atlas_pos.x > max_x:
			max_x = atlas_pos.x

		if atlas_pos.y > max_y:
			max_y = atlas_pos.y

	return Vector2i(max_x + 1, max_y + 1)
	

var voxel_material : ShaderMaterial

func texture():
	var images = []
	# Skip AIR (0), start from DIRT (1)
	for id in [1, 2, 3]: 
		var tex_path = BLOCKS[id]["texture"]
		var img = load(tex_path).get_image()
		images.append(img)
	
	# Create the Texture2DArray
	var tex_array = Texture2DArray.new()
	tex_array.create_from_images(images)
	
	# Setup the material
	voxel_material = ShaderMaterial.new()
	voxel_material.shader = load("res://scripts/voxel.gdshader")
	voxel_material.set_shader_parameter("texture_array", tex_array)

