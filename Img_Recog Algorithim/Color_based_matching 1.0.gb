extends Node

@onready var r_txt = $"UI TextBox/R"
@onready var g_txt = $"UI TextBox/G"
@onready var b_txt = $"UI TextBox/B"

@export var file_dialog: FileDialog
@export var picture_asli: TextureRect
@export var picture_hasil: TextureRect

var loaded_image : Image
var output_IMG: Image
var target_c: Vector4 = Vector4(255, 218, 67, 255)

func _ready() -> void:
	file_choser()

func file_choser():
	file_dialog.filters = PackedStringArray([
		"*.png ; PNG Images",
		"*.jpg ; JPG Images",
		"*.jpeg ; JPEG Images"
	])

	file_dialog.file_selected.connect(_on_file_selected)

func _on_open_files_pressed() -> void:
	file_dialog.popup_centered()

func _on_file_selected(path):

	var img = Image.new()
	var err = img.load(path)

	if err != OK:
		print("failed")
		return

	print("loaded")

	change_texture_original(img)

	# QUANTIZE TO 16 COLORS
	loaded_image = img


# --- IMG ---
func change_texture_original(img):
	var texture = ImageTexture.create_from_image(img)
	picture_asli.texture = texture

func change_texture_result(img):
	var texture = ImageTexture.create_from_image(img)
	picture_hasil.texture = texture


#--- INPUT ---
func _on_proses_pressed() -> void:
	get_colorInPixel(loaded_image)

#--- ALGORITHIM ---
func get_colorInPixel(img: Image):
	if img == null:
		return
		
	var width = img.get_width()
	var height = img.get_height()
	output_IMG = Image.create(width, height, false, Image.FORMAT_RGBA8)
	output_IMG.fill(Color(0, 0, 0, 0)) # Start transparent
	
	var color
	var color_v: Vector4
	var found_px
	var draw_color
	
	var red_px
	var green_px
	var blue_px
	var alpha_px
	
	for x in range(width):
		for y in range(height):
			color = img.get_pixel(x,y) * 255
			
			# -- Colour --
			red_px = color.r
			green_px = color.g
			blue_px = color.b
			alpha_px = color.a
			
			color_v = Vector4(red_px, green_px, blue_px, alpha_px)
			found_px = scan_color(color_v, target_c, Vector2i(x,y))
			
			if found_px != null:
				draw_color = Color(found_px.x / 255.0, found_px.y / 255.0, found_px.z / 255.0, 1.0)
				output_IMG.set_pixel(x, y, draw_color) #put color to x,y in the image
			
	#change the texture to the result
	picture_hasil.texture = ImageTexture.create_from_image(output_IMG)

func scan_color(color_v: Vector4, target_color: Vector4, _pos: Vector2i):
	# We want a tight check on Blue because Orange has very little blue
	# but white has a lot.
	var r_diff = abs(color_v.x - target_color.x)
	var g_diff = abs(color_v.y - target_color.y)
	var b_diff = abs(color_v.z - target_color.z)

	# Orange is high Red, medium Green, LOW Blue.
	# If Blue is too high, it's definitely not the orange you want.
	if r_diff <= int(r_txt.text) and g_diff <= int(g_txt.text) and b_diff <= int(b_txt.text):
		return color_v
		
	return null
