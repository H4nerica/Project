extends Node
#It delays initialization until nodes are ready, usually for things like:
@onready var template = $ScrollContainer/VBoxContainer/Template
@onready var box = $ScrollContainer/VBoxContainer
@onready var debug_txt = $Debug/Label

#put var here, if this is inside func it will reset each call. So put it global to remember
var id = 10

var latest_item_clicked
var last_item_clicked
var open_item_clicked
var can_click = false

var screen_size
var scroll_height
var scroll_height_changed
var keyboard_height_raw

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	screen_size = DisplayServer.window_get_size()
	scroll_height = $ScrollContainer.size.y
	await get_tree().process_frame
	load_notes()
	
	$Nav_Panel.mouse_filter = Control.MOUSE_FILTER_PASS
	$Nav_Panel/Delete_button.mouse_filter = Control.MOUSE_FILTER_STOP
	
# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	debug_txt.text = str("KH: ", keyboard_height_raw, " F: ", screen_size, " SCH: ", scroll_height_changed)
	keyboard_height_raw = DisplayServer.virtual_keyboard_get_height()
	const KEYBOARD_SCALE = 0.338 # 250 / ~720 ≈ 0.3472.. or scroll height(i choose) / keyboard_height
	var keyboard_result = keyboard_height_raw * KEYBOARD_SCALE
	
	scroll_height_changed = scroll_height - keyboard_result
	#keyboard_result = $Debug/TextEdit use this to debug the scroll size.
	$ScrollContainer.size.y = scroll_height_changed
	
func create_template():
	id += 1 #+1 each time this func is called
	var duplicate_thing = template.duplicate() #duplicate template
	duplicate_thing.mouse_filter = Control.MOUSE_FILTER_PASS
	duplicate_thing.focus_mode = Control.FOCUS_NONE
	
	box.add_child(duplicate_thing) #add this as box's child
	duplicate_thing.add_to_group("blocks")
	duplicate_thing.visible = true
	duplicate_thing.name = "block_" + str(id)
	duplicate_thing.placeholder_text = duplicate_thing.name
	duplicate_thing.selecting_enabled = false
	
	return duplicate_thing #return duplicate_thing to be used on load_notes

func change_input():
	#var text = $Debug/TextEdit.text.strip_edges().to_lower() #ignore space " enable" #for debug
	for child in box.get_children():

		if can_click:
			child.mouse_filter = Control.MOUSE_FILTER_PASS
			child.focus_mode = Control.FOCUS_ALL
			child.selecting_enabled = true
		else:
			child.mouse_filter = Control.MOUSE_FILTER_IGNORE 
			child.focus_mode = Control.FOCUS_NONE
			child.selecting_enabled = false

func _on_add_button_pressed() -> void:
	var new_block = create_template()
	await get_tree().process_frame
	new_block.grab_focus()

func _on_delete_button_pressed() -> void:
	if latest_item_clicked == null:
		return
	latest_item_clicked.queue_free() #this delete this node AFTER it finished being used
	
func _on_save_button_pressed() -> void:
	save_notes()
	
func save_notes():
	var alltext = []
	for child in box.get_children(): #the "box" is in global var
		if child == template:
			continue #if the child is template, skip it when saving
			
		alltext.append(child.text) #take all the child of this box make it to an array
	print(alltext)
	
	var file = FileAccess.open("user://notes.json", FileAccess.WRITE)
	var json_string = JSON.stringify(alltext) #take alltext then change it to json string
	file.store_string(json_string)
	file.close()
	
func load_notes():
	var file = FileAccess.open("user://notes.json", FileAccess.READ)
	var json_notes = file.get_as_text() #take as text
	file.close()
	
	var alltext = JSON.parse_string(json_notes) #convert to array
	print("Reading notes...", alltext)
	
	for text in alltext: #for each array inside alltext make new block then change the text
		var new_block = create_template()
		new_block.text = text

func _input(event):
	swiping(event)
	if is_dragging and event is InputEventMouseMotion:
		get_viewport().set_input_as_handled()
		return
	
var is_pressed := false
var start_position := Vector2.ZERO
var is_dragging := false
const DRAG_THRESHOLD := 10.0
func swiping(event):
	# START TOUCH / CLICK
	if event is InputEventScreenTouch and event.pressed:
		is_pressed = true
		start_position = event.position
		is_dragging = false
		
		#see what object being clicked
		var raything_position = event.position
		for node in get_tree().get_nodes_in_group("blocks"):
			if node.get_global_rect().has_point(raything_position):
				last_item_clicked = node
				can_click = false
				change_input()
				print(last_item_clicked, " on clicked")
				break
		
	if event is InputEventMouseButton and event.pressed:
		is_pressed = true
		start_position = event.position
		is_dragging = false
		
		#see what object being clicked
		var raything_position = event.position
		for node in get_tree().get_nodes_in_group("blocks"):
			if node.get_global_rect().has_point(raything_position):
				last_item_clicked = node
				can_click = false
				change_input()
				print(last_item_clicked, " on clicked")
				break

	# DRAG (TOUCH)
	if event is InputEventScreenDrag and is_pressed:
		if event.position.distance_to(start_position) > DRAG_THRESHOLD:
			is_dragging = true
			
		$ScrollContainer.scroll_vertical -= event.relative.y
	# DRAG (MOUSE)
	if event is InputEventMouseMotion and is_pressed and Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT):
		if event.position.distance_to(start_position) > DRAG_THRESHOLD:
			is_dragging = true
				
		$ScrollContainer.scroll_vertical -= event.relative.y

	# RELEASE
	if event is InputEventScreenTouch and not event.pressed:
		is_pressed = false
		is_dragging = false
		
		for node in get_tree().get_nodes_in_group("blocks"):
			var raything_position = event.position
			if node.get_global_rect().has_point(raything_position):
				latest_item_clicked = node
				break
				
		print(latest_item_clicked, " on release")
		if last_item_clicked != latest_item_clicked:
			return
		open_item_clicked = latest_item_clicked
		can_click = true
		change_input()
		print("its the same item", open_item_clicked)
		call_deferred("open", latest_item_clicked)
			
	if event is InputEventMouseButton and not event.pressed:
		is_pressed = false
		is_dragging = false
		
		for node in get_tree().get_nodes_in_group("blocks"):
			var raything_position = event.position
			if node.get_global_rect().has_point(raything_position):
				latest_item_clicked = node
				break
				
		print(latest_item_clicked, " on release")
		if last_item_clicked != latest_item_clicked:
			return
		open_item_clicked = latest_item_clicked
		can_click = true
		change_input()
		print("its the same item", open_item_clicked)
		call_deferred("open", latest_item_clicked)
		
#set focus on open or click
func open(node):
	if node == null:
		return
	if not is_instance_valid(node):
		return

	if node is CodeEdit:
		if node.has_focus():
			return
		
		node.grab_focus()
